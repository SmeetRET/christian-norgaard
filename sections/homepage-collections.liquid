{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 989px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (min-width: 1280px) {
    .section-{{ section.id }}-grid {
      grid-template-columns: repeat({{ section.settings.desktop_columns }}, minmax(0, 1fr));
    }
  }

  .section-{{ section.id }}-grid {
    gap: {{ section.settings.card_gap | default: 10 }}px;
  }

  .ctm-swiper-{{ section.id }} .swiper-wrapper {
    align-items: stretch;
  }

  .ctm-swiper-{{ section.id }} .swiper-slide {
    height: auto;
  }

  .ctm-swiper-{{ section.id }} .collections__tile {
    height: 280px;
  }

  @media screen and (min-width: 768px) {
    .ctm-swiper-{{ section.id }} .collections__tile {
      height: 420px;
    }
  }

  @media screen and (min-width: 1280px) {
    .ctm-swiper-{{ section.id }} .collections__tile {
      height: 618px;
    }
  }
  .ctm-swiper-{{ section.id }} .collections__frame {
    height: 100%;
    max-width: none !important;
  }

  .ctm-swiper-{{ section.id }} .collection__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ctm-swiper-{{ section.id }} .swiper-button-prev,
  .ctm-swiper-{{ section.id }} .swiper-button-next {
    color: #000;
    background: #fff;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .ctm-swiper-{{ section.id }} .swiper-button-prev::after,
  .ctm-swiper-{{ section.id }} .swiper-button-next::after {
    font-size: 16px;
    font-weight: 700;
  }

  .ctm-swiper-{{ section.id }} .swiper-button-disabled {
    opacity: 0.3;
  }
{%- endstyle -%}

{%- assign layout = section.settings.layout_type | default: 'grid' -%}
{%- assign cols = section.settings.desktop_columns | default: 3 -%}

<section class="collections-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="container">
    <div class="collections__header flex justify-center w-full title-bottom-spacing{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="title-black">
        <h2>{{ section.settings.heading | escape }}</h2>
      </div>
    </div>

    {%- if section.blocks.size > 0 -%}
      {%- if layout == 'slider' -%}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

        <div
          class="swiper ctm-swiper-{{ section.id }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          style="overflow: hidden;"
        >
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              {%- assign collection = collections[block.settings.collection] -%}
              {%- if collection.featured_image != blank and collection.featured_image.aspect_ratio > 1 -%}
                {%- assign img_orientation = 'landscape' -%}
              {%- else -%}
                {%- assign img_orientation = 'portrait' -%}
              {%- endif -%}
              <div class="swiper-slide h-auto" {{ block.shopify_attributes }}>
                <a
                  href="{{ collection.url }}"
                  role="link"
                  target="_self"
                  aria-label="{{ collection.title | escape }}"
                  class="collections__item collections__item--{{ img_orientation }} flex flex-col gap-4 h-full"
                >
                  <div class="collections__tile bg-gray-100 flex items-center justify-center md:px-[35px] px-4 py-10 w-full max-767:aspect-[16/16.8]">
                    <div class="collections__frame relative overflow-hidden w-full max-md:max-w-[290px] h-auto">
                      {%- if collection.featured_image != blank -%}
                        <img
                          src="{{ collection.featured_image | image_url: width: 600 }}"
                          srcset="
                            {{ collection.featured_image | image_url: width: 300 }} 300w,
                            {{ collection.featured_image | image_url: width: 600 }} 600w,
                            {{ collection.featured_image | image_url: width: 900 }} 900w,
                            {{ collection.featured_image | image_url: width: 1200 }} 1200w
                          "
                          sizes="(max-width: 767px) 290px, (max-width: 989px) 45vw, 25vw"
                          width="{{ collection.featured_image.width }}"
                          height="{{ collection.featured_image.height }}"
                          class="collection__img w-full h-auto"
                          alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                          loading="lazy"
                        >
                      {%- else -%}
                        {{ 'collection-1' | placeholder_svg_tag: 'collections__placeholder' }}
                      {%- endif -%}
                    </div>
                  </div>
                  <div class="content lg content-black collections__name">
                    <p class="uppercase max-lg:text-2xl! max-lg:leading-8!">{{ collection.title | escape }}</p>
                  </div>
                </a>
              </div>
            {%- endfor -%}
          </div>

          <div class="swiper-button-prev"></div>
          <div class="swiper-button-next"></div>
        </div>

        <script>
          (function () {
            function init() {
              var gap = {{ section.settings.card_gap | default: 10 }};
              new Swiper('.ctm-swiper-{{ section.id }}', {
                slidesPerView: 1.15,
                spaceBetween: gap,
                breakpoints: {
                  768:  { slidesPerView: 2,          spaceBetween: gap },
                  1280: { slidesPerView: {{ cols }}, spaceBetween: gap }
                },
                navigation: {
                  nextEl: '.ctm-swiper-{{ section.id }} .swiper-button-next',
                  prevEl: '.ctm-swiper-{{ section.id }} .swiper-button-prev'
                }
              });
            }
            if (window.Swiper) {
              init();
            } else {
              var s = document.createElement('script');
              s.src = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';
              s.onload = init;
              document.head.appendChild(s);
            }
          })();
        </script>

      {%- else -%}
        <div
          class="collections__grid section-{{ section.id }}-grid grid! items-stretch md:grid-cols-2 grid-cols-1 !gap-x-[16px] !gap-y-[40px] w-full{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        >
          {%- for block in section.blocks -%}
            {%- assign collection = collections[block.settings.collection] -%}
            {%- if collection.featured_image != blank and collection.featured_image.aspect_ratio > 1 -%}
              {%- assign img_orientation = 'landscape' -%}
            {%- else -%}
              {%- assign img_orientation = 'portrait' -%}
            {%- endif -%}
            <a
              href="{{ collection.url }}"
              role="link"
              target="_self"
              aria-label="{{ collection.title | escape }}"
              class="collections__item collections__item--{{ img_orientation }} flex flex-col gap-4"
              {{ block.shopify_attributes }}
            >
              <div class="collections__tile bg-gray-100 flex items-center justify-center md:px-[35px] 1490:px-[46px]! px-4 1490:py-[60px] py-10 w-full h-full max-[575px]:aspect-[16/17] 1199:min-h-[450px] 1490:min-h-[620px]">
                <div class="collections__frame border-4 md:border-6 border-solid border-white shadow-card relative overflow-hidden w-full max-md:max-w-[290px] h-auto">
                  {%- if collection.featured_image != blank -%}
                    <img
                      src="{{ collection.featured_image | image_url: width: 600 }}"
                      srcset="
                        {{ collection.featured_image | image_url: width: 300 }} 300w,
                        {{ collection.featured_image | image_url: width: 600 }} 600w,
                        {{ collection.featured_image | image_url: width: 900 }} 900w,
                        {{ collection.featured_image | image_url: width: 1200 }} 1200w
                      "
                      sizes="(max-width: 767px) 290px, (max-width: 989px) 45vw, 30vw"
                      width="{{ collection.featured_image.width }}"
                      height="{{ collection.featured_image.height }}"
                      class="collection__img w-full h-auto block block object-contain"
                      alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'collections__placeholder' }}
                  {%- endif -%}
                </div>
              </div>
              <div class="content lg content-black collections__name">
                <h3 class="card__heading" style="margin: 0;">
                  <span class="ctm-button btn-orange">
                    <span>{{- collection.title | escape -}}</span>
                    <span class="ctm-cta-arrow" aria-hidden="true">
                      {% render 'icon-btn-arrow' %}
                    </span>
                  </span>
                </h3>
              </div>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collections",
  "tag": "div",
  "class": "collections-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Desktop Columns",
      "default": 3,
      "info": "Grid: columns at 1280px+. Slider: visible slides at 1280px+. Tablet always shows 2."
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap Between Cards",
      "default": 10,
      "info": "Applies to both grid and slider."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Desktop Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Desktop Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
