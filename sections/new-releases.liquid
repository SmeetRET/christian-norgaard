{% style %}
  .section-id-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (max-width: 989px) {
    .section-id-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<section class="new-releases-section color-{{ section.settings.color_scheme }} general-padding section-id-{{ section.id }} ">
  <div class="container">
    <div class="new-releases__header title-bottom-spacing {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="title-black new-releases__title text-center">
        <h2>
          <span class="new-releases__title-orange">{{ section.settings.heading_highlight | escape }}</span>
          {{ section.settings.heading | escape }}
        </h2>
      </div>

      {%- if section.settings.subheading != blank -%}
        <div class="content content-gray lg new-releases__sub 2xl:max-w-[1400px] min-1439:max-w-[1030px] mx-auto text-center pt-4">
          <p>{{ section.settings.subheading | escape }}</p>
        </div>
      {%- endif -%}
    </div>

    <div class="new-releases__body flex flex-col items-center 2xl:gap-[46px] md:gap-8 gap-6 {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.series_image != blank -%}
        <div class="new-releases__series w-full overflow-hidden">
          <img
            src="{{ section.settings.series_image | image_url: width: 900 }}"
            srcset="
              {{ section.settings.series_image | image_url: width: 600 }} 600w,
              {{ section.settings.series_image | image_url: width: 900 }} 900w,
              {{ section.settings.series_image | image_url: width: 1200 }} 1200w,
              {{ section.settings.series_image | image_url: width: 1800 }} 1800w
            "
            sizes="(max-width: 767px) 100vw, 80vw"
            width="{{ section.settings.series_image.width }}"
            height="{{ section.settings.series_image.height }}"
            class="w-full h-full object-cover"
            alt="{{ section.settings.series_image.alt | default: 'New Releases Series' | escape }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_url | default: '#' }}"
          role="link"
          target="_self"
          aria-label="{{ section.settings.button_label | escape }}"
          class="btn-orange ctm-button"
        >
          <span>{{ section.settings.button_label | escape }}</span>
          <span class="ctm-cta-arrow" aria-hidden="true">
            {% render 'icon-btn-arrow' %}
          </span>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "New Releases",
  "tag": "div",
  "class": "new-releases-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading – Orange Part",
      "default": "New"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading – Black Part",
      "default": "Releases"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Description",
      "default": "Decorate your home with beautiful and impressive limited edition artwork prints that are expertly produced to transform the look of any room."
    },
    {
      "type": "image_picker",
      "id": "series_image",
      "label": "Series Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 52
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "New Releases"
    }
  ]
}
{% endschema %}
