{% style %}
  .section-id-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (max-width: 989px) {
    .section-id-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<section class="open-editions-section color-{{ section.settings.color_scheme }} section-id-{{ section.id }} overflow-hidden">
  <div class="flex items-center justify-end max-lg:flex-col">
    <div class="w-full lg:w-[43%] order-1 max-1024:order-2 {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="open-editions__content container lg:pr-0! max-lg:pt-[25px] max-lg:pb-10 {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <div class="title-white open-editions__heading">
          <h2>
            <span class="open-editions__heading-orange">{{ section.settings.heading_highlight | escape }}</span>
            {{ section.settings.heading | escape }}
          </h2>
        </div>

        {%- if section.settings.description != blank -%}
          <div class="content content-white lg content-light open-editions__desc mt-4 max-w-[400px] 2xl:max-w-[590px]">
            <p>{{ section.settings.description | escape }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div class="flex">
            <a
              href="{{ section.settings.button_url | default: '#' }}"
              role="link"
              target="_self"
              aria-label="{{ section.settings.button_label | escape }}"
              class="ctm-button btn-orange mt-6 xl:mt-11"
            >
              <span>{{ section.settings.button_label | escape }}</span>
              <span class="ctm-cta-arrow" aria-hidden="true">
                {% render 'icon-btn-arrow' %}
              </span>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
    <div class="lg:w-[57.1%] w-full relative order-2 max-1024:order-1 {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.bg_image != blank -%}
        <div class="open-editions__bg before:content-[''] before:absolute lg:before:top-0 max-lg:before:-bottom-0.5 lg:before:-left-0.5 before:left-0 lg:before:w-[455px] before:w-full lg:before:h-full before:h-[191px] lg:before:bg-[linear-gradient(270deg,#00000000_0%,#000000_100%)] before:bg-[linear-gradient(180deg,#00000000_0%,#000000_100%)]">
          <img
            src="{{ section.settings.bg_image | image_url: width: 1920 }}"
            width="1920"
            height="1096"
            class="aspect-square"
            alt="{{ section.settings.bg_image.alt | default: 'Open Editions Fine Art Photography' | escape }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Open Editions",
  "tag": "div",
  "class": "open-editions-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading – Orange Part",
      "default": "Open"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading – White Part",
      "default": "Editions"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Enjoy breathtaking artwork from the Open Editions fine artwork prints collection. Let powerful photography make a statement in your private home or business office."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Open Editions"
    }
  ]
}
{% endschema %}
