{% style %}
  .section-id-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (max-width: 989px) {
    .section-id-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<section class="limited-editions-section color-{{ section.settings.color_scheme }} section-id-{{ section.id }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="container">
    <div class="flex items-stretch min-[1800px]:gap-15! lg:gap-10 gap-6 max-lg:flex-col {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="w-full xl:basis-[calc(60%-20px)] min-[1800px]:basis-[calc(56%-30px)]">
        <div class="limited-editions__image h-full">
          {%- if section.settings.main_image != blank -%}
            <img
              src="{{ section.settings.main_image | image_url: width: 960 }}"
              width="960"
              height="840"
              loading="eager"
              class="aspect-[1.12/1] h-full object-contain max-767:object-cover max-767:aspect-[16/17.4]"
              alt="{{ section.settings.main_image.alt | default: 'Limited Edition Fine Art Photography' | escape }}"
            >
          {%- endif -%}
        </div>
      </div>
      <div class="w-full xl:basis-[calc(47.92%-20px)] min-[1800px]:basis-[calc(47.92%-30px)] flex flex-col items-center justify-center h-auto">
        <div class="limited-editions__content text-center">
          <div class="limited-editions__top flex flex-col gap-6 items-center w-full">
            <div class="title-black limited-editions__heading">
              <h2>
                <span class="limited-editions__heading-orange">{{ section.settings.heading_highlight | escape }}</span>
                {{ section.settings.heading | escape }}
              </h2>
            </div>

            {%- if section.settings.frame_image != blank -%}
              <div class="limited-editions__frame relative border-4 border-solid border-white shadow-card aspect-portrait max-767:aspect-[19/27.8] overflow-hidden xl:max-w-[168px] max-w-[129px] w-full">
                <img
                  src="{{ section.settings.frame_image | image_url: width: 320 }}"
                  width="320"
                  height="478"
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                  alt="{{ section.settings.frame_image.alt | default: 'Limited Edition Print' | escape }}"
                >
              </div>
            {%- endif -%}

            {%- if section.settings.description != blank -%}
              <div class="content content-black lg content-light text-center limited-editions__desc">
                {{ section.settings.description }}
              </div>
            {%- endif -%}
          </div>

          {%- if section.settings.button_label != blank -%}
            <a
              href="{{ section.settings.button_url | default: '#' }}"
              role="link"
              target="_self"
              aria-label="{{ section.settings.button_label | escape }}"
              class="ctm-button btn-orange justify-center 2xl:mt-11 mt-5"
            >
              <span>{{ section.settings.button_label | escape }}</span>
              <span class="ctm-cta-arrow" aria-hidden="true">
                {% render 'icon-btn-arrow' %}
              </span>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Limited Editions",
  "tag": "div",
  "class": "limited-editions-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image (Left)"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading – Orange Part",
      "default": "Limited"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading – Black Part",
      "default": "Editions"
    },
    {
      "type": "image_picker",
      "id": "frame_image",
      "label": "Small Framed Image"
    },
    {
      "type": "html",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Limited Editions"
    }
  ]
}
{% endschema %}
