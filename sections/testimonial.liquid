{%- liquid
  assign image = section.settings.image
  assign bio = section.settings.bio
  assign sig_image = section.settings.signature_image
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="testimonial-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient"
  aria-label="About Christian Nørgaard"
>
  <div class="testimonial-section__grid">
    <div class="testimonial-section__media {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if image != blank -%}
        <img
          src="{{ image | image_url: width: 600 }}"
          width="286"
          height="400"
          alt="{{ image.alt | default: 'Christian Nørgaard' | escape }}"
          loading="lazy"
          class="testimonial-section__image"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'testimonial-section__image testimonial-section__placeholder' }}
      {%- endif -%}
    </div>

    <div class="testimonial-section__content {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if bio != blank -%}
        <p class="testimonial-section__bio">{{ bio | escape }}</p>
      {%- endif -%}

      {%- if sig_image != blank -%}
        <div class="testimonial-section__signature">
          <img
            src="{{ sig_image | image_url: width: 400 }}"
            width="206"
            height="124"
            alt="Signature"
            loading="lazy"
            class="testimonial-section__signature-img"
          >
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTM Testimonial",
  "tag": "section",
  "class": "testimonial-section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Portrait Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait image"
    },
    {
      "type": "header",
      "content": "Biography Text"
    },
    {
      "type": "textarea",
      "id": "bio",
      "label": "Biography text",
      "default": "Christian Nørgaard is a high-end photographic artist whose work balances technical precision with a refined visual sensitivity. His images explore the very nature of photography — its limits, its language, and the essence of what defines an image. Rooted in a documentary approach, his practice is elevated through a careful reduction of elements and a strong poetic narrative, resulting in work that is both restrained and deeply evocative."
    },
    {
      "type": "header",
      "content": "Signature"
    },
    {
      "type": "image_picker",
      "id": "signature_image",
      "label": "Signature image"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Desktop Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Desktop Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "CTM Testimonial",
      "settings": {
        "bio": "Christian Nørgaard is a high-end photographic artist whose work balances technical precision with a refined visual sensitivity. His images explore the very nature of photography — its limits, its language, and the essence of what defines an image. Rooted in a documentary approach, his practice is elevated through a careful reduction of elements and a strong poetic narrative, resulting in work that is both restrained and deeply evocative."
      }
    }
  ]
}
{% endschema %}
