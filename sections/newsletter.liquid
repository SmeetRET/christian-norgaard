{%- liquid
  assign heading = section.settings.heading
  assign disclaimer_text = section.settings.disclaimer_text
-%}

<section
  class="ctm-newsletter color-{{ section.settings.color_scheme }}"
>
  <div class="page-width">
    <div class="ctm-newsletter__inner">
      <h2
        class="ctm-newsletter__heading"
        id="newsletter-heading-{{ section.id }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      >
        {{ heading | default: 'Newsletter' | escape }}
      </h2>

      <div class="ctm-newsletter__right {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {% form 'customer', class: 'ctm-newsletter__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}
            <p class="ctm-newsletter__success" tabindex="-1" autofocus>
              {{ 'newsletter.success' | t }}
            </p>
          {%- else -%}
            <div class="ctm-newsletter__field-row">
              <label class="ctm-newsletter__label" for="NewsletterForm--{{ section.id }}"> Email </label>
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="ctm-newsletter__input"
                value="{{ form.email }}"
                placeholder="Email"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="Newsletter-error--{{ section.id }}"
                {% endif %}
                required
              >
              <button
                type="submit"
                class="ctm-newsletter__submit"
                name="commit"
                aria-label="{{ 'newsletter.button_label' | t }}"
                {% if disclaimer_text != blank %}
                  disabled
                {% endif %}
              >
                Subscribe
              </button>
            </div>

            {%- if form.errors -%}
              <p class="ctm-newsletter__error" id="Newsletter-error--{{ section.id }}">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </p>
            {%- endif -%}
          {%- endif -%}

          {%- if disclaimer_text != blank -%}
            <div class="ctm-newsletter__disclaimer">
              <input
                type="checkbox"
                id="ctm-newsletter-consent--{{ section.id }}"
                class="ctm-newsletter__consent"
                aria-required="true"
                aria-labelledby="newsletter-consent-text"
              >
              <label
                for="ctm-newsletter-consent--{{ section.id }}"
                class="ctm-newsletter__consent-label"
                aria-hidden="true"
                aria-labelledby="newsletter-consent-text"
              >
                <span class="ctm-newsletter__consent-box"></span>
              </label>
              <p class="ctm-newsletter__disclaimer-text" id="newsletter-consent-text">{{ disclaimer_text | escape }}</p>
            </div>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% javascript %}
  document.querySelectorAll('.ctm-newsletter__form').forEach((form) => {
    const checkbox = form.querySelector('.ctm-newsletter__consent');
    const submitBtn = form.querySelector('.ctm-newsletter__submit');
    if (!checkbox || !submitBtn) return;
    checkbox.addEventListener('change', () => {
      submitBtn.disabled = !checkbox.checked;
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "ctm-newsletter-wrapper",
  "disabled_on": { "groups": ["header"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Newsletter"
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer text",
      "default": "Subscribe for occasional updates: availability changes, project wrap-ups, and a couple of timely notes. Light cadence, no spam."
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "settings": {
        "heading": "Newsletter",
        "disclaimer_text": "Subscribe for occasional updates: availability changes, project wrap-ups, and a couple of timely notes. Light cadence, no spam."
      }
    }
  ]
}
{% endschema %}
