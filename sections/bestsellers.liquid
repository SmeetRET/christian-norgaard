{%- liquid
  assign section_id = 'bestsellers-' | append: section.id
  assign collection = collections[section.settings.collection]
  assign products_limit = section.settings.products_limit | default: 8
  assign heading = section.settings.heading
  assign heading_hl = section.settings.heading_highlight
-%}

{% style %}
  .section-id-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 989px) {
    .section-id-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
  .bestsellers-grid-{{ section.id }} { display: grid; }
  .bestsellers-swiper-{{ section.id }} { display: none; }

  @media screen and (max-width: 767px) {
    .bestsellers-grid-{{ section.id }} { display: none !important; }
    .bestsellers-swiper-{{ section.id }} { display: block !important; }
  }
{% endstyle %}

<section
  id="{{ section_id }}"
  class="bestsellers-section color-{{ section.settings.color_scheme }} section-id-{{ section.id }}"
  aria-label="{{ heading | escape }}{% if heading_hl != blank %} {{ heading_hl | escape }}{% endif %}"
>
  <div class="container">
    <div class="bestsellers__inner">
      {%- if heading != blank or heading_hl != blank -%}
        <div class="bestsellers__header flex flex-col gap-4 items-center text-center w-full title-bottom-spacing {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <div class="title-black">
            <h2 class="bestsellers__heading">
              {%- if heading_hl != blank -%}
                <span class="new-releases__title-orange">{{ heading_hl | escape }}</span>
              {%- endif -%}
              {%- if heading != blank -%}{{ heading | escape }}{%- endif -%}
            </h2>
          </div>

          {%- if section.settings.subheading != blank -%}
            <div class="content lg content-gray 2xl:max-w-[1400px] max-w-[980px] mx-auto">
              <p>{{ section.settings.subheading | escape }}</p>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if collection != blank and collection.products_count > 0 -%}
        <div
          class="bestsellers-grid-{{ section.id }} hidden items-stretch md:grid! xl:grid-cols-4 md:grid-cols-2 grid-cols-1 !gap-x-[16px] !gap-y-[32px] w-full {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          aria-label="Bestseller products"
        >
          {%- for product in collection.products limit: products_limit -%}
            <a
              href="{{ product.url }}"
              class="bestsellers__card bg-gray-100 flex items-center justify-center md:px-[35px] px-4 py-10 w-full"
              aria-label="{{ product.title | escape }}"
            >
              <div class="bestsellers__frame relative border-4 md:border-6 border-solid border-white shadow-card overflow-hidden w-full max-md:max-w-[209px]">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '400, 600, 800',
                      class: 'bestsellers__img w-full h-auto block',
                      alt: product.featured_image.alt
                    | default: product.title
                    | escape
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'bestsellers__img w-full h-auto block' }}
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>

        <div
          class="swiper bestsellers-swiper-{{ section.id }} overflow-hidden -mx-4! px-4!"
          aria-roledescription="carousel"
          aria-label="Bestseller products slider"
        >
          <div class="swiper-wrapper">
            {%- for product in collection.products limit: products_limit -%}
              <div
                class="swiper-slide h-auto! bg-gray-100 flex! items-center justify-center md:px-[35px max-767:aspect-[20_/_14.9] max-[575px]:aspect-[11_/_14.9]"
                role="group"
                aria-roledescription="slide"
                aria-label="{{ forloop.index }} of {{ collection.products | size | at_most: products_limit }} z"
              >
                <a
                  href="{{ product.url }}"
                  class="bestsellers__card border-4 border-solid border-white shadow-card overflow-hidden w-full flex max-md:max-w-[201px]"
                  aria-label="{{ product.title | escape }}"
                >
                  <div class="bestsellers__frame ">
                    {%- if product.featured_image != blank -%}
                      {{
                        product.featured_image
                        | image_url: width: 600
                        | image_tag:
                          loading: 'lazy',
                          widths: '300, 400, 600',
                          class: 'bestsellers__img w-full h-auto block',
                          alt: product.featured_image.alt
                        | default: product.title
                        | escape
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'bestsellers__img w-full h-auto block' }}
                    {%- endif -%}
                  </div>
                </a>
              </div>
            {%- endfor -%}
          </div>
          <div
            class="collections__nav-row left-0 right-0 justify-center items-center z-10 pointer-events-none static translate-y-0 gap-[44px] mt-6 hidden max-md:flex!"
            aria-hidden="true"
          >
            <button
              type="button"
              class="collections__nav collections__nav--prev collections-prev-{{ section.id }} pointer-events-auto text-lg leading-6 uppercase font-roc-grotesk text-black"
              aria-label="Previous slide"
            >
              PREV
            </button>
            <button
              type="button"
              class="collections__nav collections__nav--next collections-next-{{ section.id }} pointer-events-auto text-lg leading-6 uppercase font-roc-grotesk text-black"
              aria-label="Next slide"
            >
              NEXT
            </button>
          </div>
        </div>

      {%- elsif request.design_mode -%}
        <div class="bestsellers__empty-state text-center py-40 text-black/40 font-roc-grotesk text-16">
          Select a collection in the section settings to display products.
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="bestsellers__footer xl:pt-15 pt-10 flex justify-center max-md:hidden">
          <a
            href="{{ section.settings.button_url | default: collection.url | default: '#' }}"
            role="link"
            aria-label="{{ section.settings.button_label | escape }}"
            class="btn-orange ctm-button"
          >
            <span>{{ section.settings.button_label | escape }}</span>
            <span class="ctm-cta-arrow" aria-hidden="true">
              {% render 'icon-btn-arrow' %}
            </span>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    function initBestsellersSwiper() {
      const el = document.querySelector('.bestsellers-swiper-{{ section.id }}');
      if (!el || !window.Swiper) {
        return;
      }

      if (el.swiper) {
        el.swiper.destroy(true, true);
      }

      new Swiper(el, {
        slidesPerView: 1.27,
        spaceBetween: 18,
        loop: true,
        watchSlidesProgress: true,
        a11y: { enabled: true },
        navigation: {
          nextEl: el.querySelector('.collections__nav--next'),
          prevEl: el.querySelector('.collections__nav--prev'),
        },
      });
    }

    if (document.readyState === 'complete') {
      initBestsellersSwiper();
    } else {
      window.addEventListener('load', initBestsellersSwiper);
    }

    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail && e.detail.sectionId === '{{ section.id }}') {
        initBestsellersSwiper();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Bestsellers",
  "tag": "div",
  "class": "bestsellers-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading – Orange Part"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Description",
      "default": "Christian's newest best-selling artwork prints. Transform your spaces with unique moments photographed from all corners of the planet."
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Number of products",
      "default": 8
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Bestsellers"
    }
  ]
}
{% endschema %}
